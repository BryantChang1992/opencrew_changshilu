{
  "id": "task-followup",
  "kind": "utility",
  "name": "Task Follow-up",
  "description": "任务跟踪插件 - 强制保证派单汇报机制的有效性，自动提醒和升级超时任务",
  "uiHints": {
    "reportIntervalMinutes": {
      "label": "汇报间隔（分钟）",
      "placeholder": "15",
      "help": "派单后必须汇报的时间间隔，默认15分钟",
      "advanced": false
    },
    "maxEscalateCount": {
      "label": "最大升级次数",
      "placeholder": "3",
      "help": "任务超时后最多升级多少次，达到上限后会通知CEO",
      "advanced": false
    },
    "enableAutoEscalation": {
      "label": "启用自动升级",
      "help": "任务超时后是否自动升级（不汇报则升级）"
    },
    "dataFilePath": {
      "label": "数据文件路径",
      "placeholder": "~/.openclaw/task-followup/tasks.json",
      "help": "任务数据的存储路径",
      "advanced": true
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "reportIntervalMinutes": {
        "type": "number",
        "minimum": 5,
        "maximum": 60,
        "default": 15
      },
      "maxEscalateCount": {
        "type": "number",
        "minimum": 1,
        "maximum": 10,
        "default": 3
      },
      "enableAutoEscalation": {
        "type": "boolean",
        "default": true
      },
      "dataFilePath": {
        "type": "string",
        "default": "~/.openclaw/task-followup/tasks.json"
      }
    }
  }
}
